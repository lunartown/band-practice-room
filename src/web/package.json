{
  "name": "hapjusil-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "build:app": "tsc --noEmit && vite build --mode capacitor",
    "preview": "vite preview --host 0.0.0.0",
    "app:sync": "npm run build:app && cap sync",
    "app:android": "npm run app:sync && cap open android",
    "app:ios": "npm run app:sync && cap open ios",
    "app:ota": "npm run build:app && npx @capgo/cli bundle upload"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capgo/capacitor-updater": "^8.49.7",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@vercel/analytics": "^2.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
